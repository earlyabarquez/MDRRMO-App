<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Full screen Google Map -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top overlay — title + legend -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardMapHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Header row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nearby hazards"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_lg"
                    android:textStyle="bold" />

                <!-- Loading indicator -->
                <ProgressBar
                    android:id="@+id/mapProgressBar"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:visibility="gone" />

                <!-- Hazard count badge -->
                <TextView
                    android:id="@+id/tvHazardCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 active"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

            </LinearLayout>

            <!-- Legend row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Low -->
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/circle_severity_low"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Low"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_xs"
                    android:layout_marginEnd="10dp" />

                <!-- Moderate -->
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/circle_severity_moderate"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Moderate"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_xs"
                    android:layout_marginEnd="10dp" />

                <!-- High -->
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/circle_severity_high"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="High"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_xs"
                    android:layout_marginEnd="10dp" />

                <!-- Critical -->
                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/circle_severity_critical"
                    android:layout_marginEnd="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Critical"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_xs" />

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- My location button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMyLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:layout_marginBottom="80dp"
        android:src="@drawable/ic_my_location"
        android:contentDescription="My location"
        app:backgroundTint="@color/surface"
        app:fabSize="mini"
        app:tint="@color/primary"
        app:elevation="4dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>